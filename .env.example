# HTTP
HOST=0.0.0.0
PORT=8000

# Inference mode: hybrid | faster | triton | base
# hybrid is fastest but only verified on sm_120 (RTX 5090).
# Use `faster` as a safe fallback on sm_86/sm_89 (RTX 30xx/40xx).
OMNIVOICE_MODE=hybrid

# Model dtype: bfloat16 | float16 | float32
OMNIVOICE_DTYPE=bfloat16

# CUDA device index
CUDA_DEVICE=0

# Local path to the OmniVoice snapshot baked into the image.
# Set to `k2-fsa/OmniVoice` if you prefer downloading from HF at startup.
OMNIVOICE_MODEL_PATH=/app/models/OmniVoice

# Telephony output format
SAMPLE_RATE_OUT=8000

# Max text length per request (chars). Requests above are rejected.
MAX_TEXT_LENGTH=500

# Voices
VOICES_DIR=./voices
VOICES_CONFIG=./voices/voices.json

# Request queue size. Requests above are rejected with 503.
QUEUE_MAXSIZE=64

# Per-request timeout (seconds) waiting for GPU worker
REQUEST_TIMEOUT=30

# Mock mode (no GPU, returns a sine wave). Set to 1 for local HTTP testing.
MOCK_ENGINE=0

# Prewarm runner on startup (runs one dummy generate per voice)
PREWARM=1

# Log level
LOG_LEVEL=INFO
